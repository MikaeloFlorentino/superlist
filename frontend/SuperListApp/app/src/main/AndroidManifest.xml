<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".SuperListApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SuperList"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.VerifyCodeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.ProfileSetupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.familias.FamiliasActivity"
            android:exported="false" />

        <activity
            android:name=".ui.familias.CrearFamiliaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.familias.MiembrosActivity"
            android:exported="false" />

        <activity
            android:name=".ui.familias.InvitacionesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.catalogo.CatalogoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.catalogo.CrearArticuloActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.listas.ListasActivity"
            android:exported="false" />

        <activity
            android:name=".ui.listas.CrearListaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.listas.ListaDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.compras.ModoCompraActivity"
            android:exported="false" />

        <activity
            android:name=".ui.compras.PendientesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.historial.HistorialActivity"
            android:exported="false" />

        <activity
            android:name=".ui.historial.DetalleHistorialActivity"
            android:exported="false" />

        <activity
            android:name=".ui.familias.UnirseFamiliaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>
</manifest>
